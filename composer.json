{
    "name": "alesha/notification-service",
    "type": "project",
    "description": "REST API service for guaranteed message delivery via Email and Telegram.",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.9",
        "mateusjunges/laravel-kafka": "^2.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "echo 'Запусти в терминале хоста: docker compose run --rm phpstan'",
        "format": "pint",
        "test": "pest",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "db:reset-all": [
            "php artisan migrate:fresh",
            "php artisan infra:reset",
            "php artisan cache:clear"
        ],
        "deploy:warmup": [
            "php artisan bloom:warmup --chunk=10000"
        ],
        "db:status": [
            "php artisan infra:status"
        ],
        "db:clickhouse-top": [
            "docker compose exec clickhouse clickhouse-client --query \"SELECT * FROM analytics.notifications_report ORDER BY updated_at DESC LIMIT 5\""
        ],
        "db:redis-keys": [
            "docker compose exec redis redis-cli KEYS \"*\""
        ]
    },
    "config": {
        "platform": {
            "php": "8.3.30"
        },
        "provide": {
            "ext-rdkafka": "6.0.3"
        },
        "policy.advisories.ignore-id": [
            "PKSA-mdq4-51ck-6kdq",
            "PKSA-8qx3-n5y5-vvnd",
            "PKSA-q46n-4fdk-zjr4",
            "PKSA-qzrn-rnz3-85w1",
            "PKSA-w7xr-vk7n-rstm"
        ],
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
