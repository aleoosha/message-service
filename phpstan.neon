parameters:
    level: 5
    paths:
        - app
        - routes
    excludePaths:
        - vendor/*
    
    treatPhpDocTypesAsCertain: false
    
    ignoreErrors:
        - '#Call to an undefined static method Illuminate\\Support\\Facades\\Redis::executeRaw\(\)\.#'
        - '#Result of static method Illuminate\\Support\\Facades\\Redis::keys\(\) \(void\) is used\.#'
